{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "noEmit": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "types": [
      "vite/client",
      "node"
    ],
    "preserveSymlinks": true
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"
  ]
}