{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://ats.local/schemas/rubric.schema.json",
  "title": "ATS Structured Interview Rubric",
  "description": "İş-ilişkili (job-related) yapılandırılmış mülakat rubric'i. Numeric/comparative scoring, ranking, affect ve korumalı-özellik (protected-attribute) kriterleri FORBIDDEN. Bu bir SOZLESME semasidir; runtime rubric editor/enforcement P1/gate-locked.",
  "$defs": {
    "ref": { "type": "string", "pattern": "^[A-Za-z][A-Za-z0-9._:-]*$", "minLength": 1 }
  },
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "rubric_version_ref", "locale", "criteria"],
  "properties": {
    "schema_version": { "const": "rubric/v1" },
    "rubric_version_ref": { "$ref": "#/$defs/ref" },
    "locale": { "type": "string", "pattern": "^[a-z]{2}-[A-Z]{2}$" },
    "criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["criterion_id", "criterion_type", "job_relatedness_rationale_ref", "allowed_evidence_types"],
        "properties": {
          "criterion_id": { "$ref": "#/$defs/ref" },
          "criterion_type": { "enum": ["skill", "competency", "experience", "knowledge", "work_sample"] },
          "job_relatedness_rationale_ref": { "$ref": "#/$defs/ref" },
          "allowed_evidence_types": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": { "enum": ["interview_response", "work_sample", "portfolio", "reference_check"] }
          }
        }
      }
    }
  }
}
